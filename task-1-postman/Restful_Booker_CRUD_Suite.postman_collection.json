                  "pm.test(\"Booking ID is a number and stored\", function () {",
                  "    pm.expect(json.bookingid).to.be.a(\"number\");",
                  "});",
                  "",
                  "pm.test(\"Created booking has correct first name\", function () {",
                  "    pm.expect(json.booking.firstname).to.eql(pm.environment.get(\"firstName\"));",
                  "});",
                  "",
                  "pm.test(\"Created booking has correct last name\", function () {",
                  "    pm.expect(json.booking.lastname).to.eql(pm.environment.get(\"lastName\"));",
                  "});",
                  "",
                  "pm.test(\"Deposit paid is boolean\", function () {",
                  "    pm.expect(json.booking.depositpaid).to.be.a(\"boolean\");",
                  "});",
                  "",
                  "pm.test(\"Booking dates exist\", function () {",
                  "    pm.expect(json.booking.bookingdates.checkin).to.be.a(\"string\");",
                  "    pm.expect(json.booking.bookingdates.checkout).to.be.a(\"string\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
