                  "pm.environment.set(\"lastName\", \"QA\" + Math.floor(Math.random() * 10000));",
                  "pm.environment.set(\"totalPrice\", Math.floor(Math.random() * 400) + 100);",
                  "pm.environment.set(\"bookingId\", \"\");",
                  "",
                  "console.log(`Creating booking for: ${pm.environment.get(\"firstName\")} ${pm.environment.get(\"lastName\")}`);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disabledSystemHeaders": {
              "accept": true
            }
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": " application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"firstname\": \"{{firstName}}\",\r\n  \"lastname\": \"{{lastName}}\",\r\n  \"totalprice\": {{totalPrice}},\r\n  \"depositpaid\": true,\r\n  \"bookingdates\": {\r\n    \"checkin\": \"2025-06-01\",\r\n    \"checkout\": \"2025-06-10\"\r\n  },\r\n  \"additionalneeds\": \"Breakfast\"\r\n}",
